{
  "name": "share-of-search",
  "version": "1.0.0",
  "description": "Monthly brand share of search tracker using DataForSEO + Supabase",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
